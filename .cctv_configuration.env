# === NAS Credentials ===
username=your_nas_smb_username
password=your_nas_smb_password
domain=WORKGROUP
NAS_IP="your_nas_smb_ip_address"
NAS_SHARENAME="your_nas_smb_share"

# === Camera RTSP Credentials ===
CAMERA_USER="your_rtsp_username"
CAMERA_PASS="your_rtsp_password"
CAMERA_IP="your_camera_ip_address"
CAMERA_PORT="your_camera_rtsp_port"

# === Other Configuration ===
MOUNT_PATH="/mnt/cctv_storage"
TARGET_DIR="/mnt/cctv_storage/footage"